# ── AMD Track 1 harness env ─────────────────────────────────────────────
# At EVAL time the harness injects these — do NOT bundle a real .env in the image.
# For LOCAL DEV, set your own Fireworks key + the public base URL.

FIREWORKS_API_KEY=your_dev_key_here
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
# Comma-separated allowed model IDs (harness publishes exact IDs at eval).
# Launch-day Track 1 list (verify against the ALLOWED_MODELS the harness sets):
ALLOWED_MODELS=accounts/fireworks/models/gemma-4-31b-it,accounts/fireworks/models/gemma-4-26b-a4b-it,accounts/fireworks/models/kimi-k2p7-code,accounts/fireworks/models/minimax-m3

# ── Free local tier (tokens count as ZERO) ──────────────────────────────
# Qwen 0.5B: fast, small image, safe under the 60s ready + 30s/request caps.
LOCAL_MODEL=Qwen/Qwen2.5-0.5B-Instruct

# ── Router thresholds ───────────────────────────────────────────────────
MIN_CONFIDENCE=0.65
PREFLIGHT_SKIP_ABOVE=0.9
N_SAMPLES=0
LOCAL_MAX_TOKENS=512
REMOTE_MAX_TOKENS=1024

# Answer parser: raw | numeric | mcq | yes_no | boxed | summary | entities
ANSWER_EXTRACTOR=raw

# ── Harness runtime (optional overrides) ────────────────────────────────
# INPUT_PATH=/input/tasks.json
# OUTPUT_PATH=/output/results.json
# TOTAL_BUDGET_S=540
# PER_TASK_BUDGET_S=28
