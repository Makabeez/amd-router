# Fireworks AI
FIREWORKS_API_KEY=your_key_here
FIREWORKS_MODEL=accounts/fireworks/models/llama-v3p1-8b-instruct

# Local model — confirm size cap on Jul 6 against the standardized eval env
LOCAL_MODEL=Qwen/Qwen2.5-1.5B-Instruct

# Router thresholds (tune via scripts/calibrate_thresholds.py)
MIN_CONFIDENCE=0.65
PREFLIGHT_SKIP_ABOVE=0.85
N_SAMPLES=0

# Generation
LOCAL_MAX_TOKENS=512
REMOTE_MAX_TOKENS=512

# Answer parser: raw | first_line | numeric | mcq | yes_no | boxed
ANSWER_EXTRACTOR=raw
