# Fireworks AI — reasoning-model catalog (Jul 2026)
FIREWORKS_API_KEY=your_key_here

# Single-model default (used by src/main.py if TieredRemoteBackend is not wired)
FIREWORKS_MODEL=accounts/fireworks/models/deepseek-v4-pro

# Per-tier overrides (used by TieredRemoteBackend). Empirical cost ordering:
# deepseek-v4-pro (~36 tok) < kimi-k2p6 (~54 tok) < glm-5p2 (~87 tok) per 1-word answer
FIREWORKS_MODEL_SMALL=accounts/fireworks/models/deepseek-v4-pro
FIREWORKS_MODEL_MEDIUM=accounts/fireworks/models/kimi-k2p6
FIREWORKS_MODEL_LARGE=accounts/fireworks/models/glm-5p2

# Local model — confirm size cap on Jul 6 against the standardized eval env
LOCAL_MODEL=Qwen/Qwen2.5-1.5B-Instruct

# Router thresholds (tune via scripts/calibrate_thresholds.py)
MIN_CONFIDENCE=0.65
PREFLIGHT_SKIP_ABOVE=0.85
N_SAMPLES=0

# Generation — reasoning models need headroom, not the 512 default
LOCAL_MAX_TOKENS=512
REMOTE_MAX_TOKENS=1024

# Answer parser: raw | first_line | numeric | mcq | yes_no | boxed
# All extractors auto-strip reasoning traces (<think>, "Final Answer:" markers).
ANSWER_EXTRACTOR=raw
